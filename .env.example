# Production database connection (Supabase direct connection or session pooler, port 5432)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# Throwaway Postgres for integration tests (its public schema is DROPPED each test)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poller_test
# OpenRouter (AI review). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Optional per-stage model overrides (OpenRouter ids). Unset = reviewer default (reviewer/llm.py DEFAULT_MODEL).
REVIEW_MODEL_STAGE1=anthropic/claude-haiku-4.5
REVIEW_MODEL_STAGE2=anthropic/claude-haiku-4.5
# Langfuse (LLM observability). Free Hobby tier: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
# Fraction of job reviews to trace (1.0 = all). Lower during large backfills to save free-tier units.
LANGFUSE_SAMPLE_RATE=1.0

# ── Billing (Stripe) — Phase 1 chargeable beta ────────────────────────────────
# Secret key (test mode: sk_test_...). https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for /api/stripe/webhook. From `stripe listen` (whsec_...)
# locally, or the Stripe dashboard webhook endpoint in prod.
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring Price ids for each tier (create Products+Prices in Stripe first).
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PRO=price_...
# Absolute site origin for Checkout/Portal success + return URLs (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# ── On-demand review worker (reviewer.worker) ─────────────────────────────────
# Seconds the worker sleeps when the review_requests queue is empty (default 15).
REVIEW_WORKER_POLL_SECONDS=15

# ── Supabase service role (Phase 2) ───────────────────────────────────────────
# WARNING: this key BYPASSES RLS and can administer auth users. Server-side ONLY —
# never expose it to the browser (do NOT prefix it NEXT_PUBLIC_). Account deletion
# (lib/accountDeletion.ts) needs it to call auth.admin.deleteUser. Find it under
# Supabase → Project Settings → API → service_role secret. If unset, account deletion
# fails loudly at call time (lib/supabase/admin.ts) rather than at import.
SUPABASE_SERVICE_ROLE_KEY=

# ── Account-deletion erasure ledger (lib/accountDeletion.ts) ───────────────────
# HMAC key for the account_deletions.email_hash proof-of-deletion column. hashEmail
# HMAC-SHA256s the deleted user's email with this so the retained hash can't be reversed
# by dictionary-hashing candidate addresses. Use a long random value; keep it STABLE
# (rotating re-anonymizes past hashes). REQUIRED: account deletion fails closed (throws)
# if unset — do NOT prefix NEXT_PUBLIC_.
ACCOUNT_DELETION_HASH_SECRET=

# ── Legal / support (Phase 2) ─────────────────────────────────────────────────
# Support/contact address surfaced as a mailto on the legal pages, auth footers, and
# the error page. Public (inlined into the client bundle). When unset, those links
# simply don't render.
NEXT_PUBLIC_SUPPORT_EMAIL=support@your-app.example.com

# ── Admin console (Phase 2, /admin/tenants) ───────────────────────────────────
# Comma-separated list of operator emails allowed to view the per-tenant admin page.
# Compared case-insensitively against the verified JWT email. UNSET = no admins (fail
# closed — nobody can reach /admin/tenants).
ADMIN_EMAILS=

# ── OpenRouter spend alert (Phase 2, observability.spend_alert cron) ───────────
# Slack/Discord-compatible incoming webhook the spend-alert posts to when a threshold
# trips. If unset AND a threshold trips, the job logs ERROR and exits nonzero (never a
# silent pass) so the Railway cron surfaces the failure.
ALERT_WEBHOOK_URL=
# Alert if the trailing-24h OpenRouter burn exceeds this many USD (default 10).
SPEND_ALERT_DAILY_USD=10
# Alert if remaining OpenRouter credits fall below this many USD (default 20).
SPEND_ALERT_CREDITS_FLOOR_USD=20
