{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "watchPatterns": [
      "company_discovery/**",
      "requirements.txt",
      "pyproject.toml",
      "railway.discovery.json",
      "schema.sql"
    ]
  },
  "deploy": {
    "startCommand": "python -m company_discovery",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 100
  }
}
