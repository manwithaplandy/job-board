# Production database connection (Supabase direct connection or session pooler, port 5432)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# Throwaway Postgres for integration tests (its public schema is DROPPED each test)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poller_test
# OpenRouter (AI review). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Optional per-stage model overrides (OpenRouter ids). Unset = reviewer default (reviewer/llm.py DEFAULT_MODEL).
REVIEW_MODEL_STAGE1=anthropic/claude-haiku-4.5
REVIEW_MODEL_STAGE2=anthropic/claude-haiku-4.5
# Langfuse (LLM observability). Free Hobby tier: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
# Fraction of job reviews to trace (1.0 = all). Lower during large backfills to save free-tier units.
LANGFUSE_SAMPLE_RATE=1.0

# ── Billing (Stripe) — Phase 1 chargeable beta ────────────────────────────────
# Secret key (test mode: sk_test_...). https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for /api/stripe/webhook. From `stripe listen` (whsec_...)
# locally, or the Stripe dashboard webhook endpoint in prod.
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring Price ids for each tier (create Products+Prices in Stripe first).
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PRO=price_...
# Absolute site origin for Checkout/Portal success + return URLs (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# ── On-demand review worker (reviewer.worker) ─────────────────────────────────
# Seconds the worker sleeps when the review_requests queue is empty (default 15).
REVIEW_WORKER_POLL_SECONDS=15
