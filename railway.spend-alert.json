{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "watchPatterns": [
      "observability/**",
      "requirements.txt",
      "pyproject.toml",
      "railway.spend-alert.json",
      "schema.sql"
    ]
  },
  "deploy": {
    "startCommand": "python -m observability.spend_alert",
    "cronSchedule": "0 * * * *",
    "restartPolicyType": "NEVER"
  }
}
